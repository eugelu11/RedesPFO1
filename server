import socket
import threading
import sqlite3

# Configuración
HEADER = 64
PORT = 5050
SERVER = "127.0.0.1"
ADDR = (SERVER, PORT)
FORMAT = 'utf-8'
MENSAJE_DESCONEXION = "!DESCONECTAR"

server = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
server.bind(ADDR)

def init_db():
    conn = sqlite3.connect("chat.db")
    cursor = conn.cursor()

    cursor.execute("""
    CREATE TABLE IF NOT EXISTS messages (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        content TEXT
    )
    """)

    conn.commit()
    conn.close()

def cliente(conn_socket, addr):
    print(f"[NUEVA CONEXIÓN] {addr} conectado.")

    db = sqlite3.connect("chat.db")
    cursor = db.cursor()

    conectado = True
    while conectado:
        try:
            len_mensaje = conn_socket.recv(HEADER).decode(FORMAT)

            if not len_mensaje:
                break

            len_mensaje = int(len_mensaje)
            mensaje = conn_socket.recv(len_mensaje).decode(FORMAT)

            if mensaje == MENSAJE_DESCONEXION:
                conectado = False
            else:
                # Guardar en DB
                cursor.execute(
                    "INSERT INTO messages (content) VALUES (?)",
                    (mensaje,)
                )
                db.commit()

            print(f"[{addr}] {mensaje}")

        except:
            print(f"[ERROR] Conexión con {addr} perdida.")
            break

    db.close()
    conn_socket.close()
    print(f"[DESCONECTADO] {addr}")

def empezar():
    server.listen()
    print(f"[ESCUCHANDO] Servidor en {SERVER}:{PORT}")

    while True:
        conn_socket, addr = server.accept()
        thread = threading.Thread(target=cliente, args=(conn_socket, addr))
        thread.start()

        print(f"[CONEXIONES ACTIVAS] {threading.active_count() - 1}")

init_db()
print("[INICIANDO] Servidor...")
empezar()





